# =============================================================================
# Ojas — environment configuration.
#
# Copy this file to `.env` (same directory) and fill in real values:
#     cp .env.example .env
#     chmod 600 .env         # owner-only read on Linux/Mac
#
# The backend auto-loads `.env` on startup. Restart the FastAPI server after
# changing values. `.env` is git-ignored so secrets never end up in commits.
# =============================================================================


# -----------------------------------------------------------------------------
# REQUIRED — the agent can't do anything without these.
# -----------------------------------------------------------------------------

# Anthropic API key. Get one at https://console.anthropic.com
ANTHROPIC_API_KEY="sk-ant-..."


# -----------------------------------------------------------------------------
# ROOT (admin) user — owns the VM, can do anything.
#
# Logging in with these credentials grants `role=root`: bypasses the workspace
# jail (full filesystem + shell access), can see every user's sessions, can
# kill any spawned process via the admin endpoints. ONLY set these to YOUR
# personal credentials.
#
# Plaintext is fine for a self-hosted personal VM. If you'd rather pre-hash,
# leave OJAS_ROOT_PASSWORD blank and set OJAS_ROOT_PASSWORD_HASH to a bcrypt
# hash instead — the code prefers the hash if both are set.
# -----------------------------------------------------------------------------

OJAS_ROOT_EMAIL="you@example.com"
OJAS_ROOT_PASSWORD="change-me-to-a-strong-password"
# OJAS_ROOT_PASSWORD_HASH=""    # optional bcrypt hash; overrides plaintext above


# -----------------------------------------------------------------------------
# WORKSPACE — where the agent builds projects on disk.
#
# Default per platform if unset:
#   macOS:   ~/Desktop/Ojas
#   Linux:   ~/ojas
#   Windows: ~/Ojas
#
# On a Linux VM, set this explicitly to a path that exists and has free
# space (e.g. `/srv/ojas`). The folder is created on first use.
# -----------------------------------------------------------------------------

# OJAS_DEFAULT_WORKSPACE="/srv/ojas"


# -----------------------------------------------------------------------------
# MULTI-USER — whether anyone besides root can sign up.
#
# Set to "false" to lock signup down (only root has an account). Default is
# "true" so you can hand the URL to other people and let them register.
# -----------------------------------------------------------------------------

# OJAS_ALLOW_SIGNUP=true


# -----------------------------------------------------------------------------
# OPTIONAL — model + agent behaviour overrides.
# -----------------------------------------------------------------------------

# Which Anthropic model to use. Default is whatever the codebase pins.
# AGENT_MODEL="claude-opus-4-6"

# Hard per-call timeout for any single LLM request (seconds). Default 300.
# AGENT_LLM_TIMEOUT_SECS=300

# Default bash timeout in milliseconds for a single command. Default 180000 (3 min).
# AGENT_BASH_DEFAULT_TIMEOUT_MS=180000

# Per-turn iteration cap. 0 = unlimited (default; this is an autonomous agent).
# AGENT_MAX_ITERATIONS=0

# Auto-compaction trigger (input tokens). Default 100000.
# CLAUDE_CODE_AUTO_COMPACT_INPUT_TOKENS=100000


# -----------------------------------------------------------------------------
# OPTIONAL — alternative LLM providers (drop-in replacements for Anthropic).
#
# Setting these doesn't switch providers automatically; the codebase chooses
# based on its module-level `_provider` setting. Set the matching env vars
# only for the provider you actually use.
# -----------------------------------------------------------------------------

# MiniMax (OpenAI-compatible)
# MINIMAX_API_KEY=""
# MINIMAX_BASE_URL="https://api.minimax.io/v1"

# Generic OpenAI-compatible endpoint (Together, DeepSeek, Groq, vLLM, etc.)
# AGENT_API_KEY=""
# AGENT_BASE_URL=""

# OpenAI
# OPENAI_API_KEY=""
# OPENAI_BASE_URL=""


# -----------------------------------------------------------------------------
# OPTIONAL — git auto-commit / push.
#
# If both are set, the agent will push to GitHub at the end of each turn that
# modified files. Skip them for local-only use.
# -----------------------------------------------------------------------------

# GITHUB_TOKEN=""
# GITHUB_REPO="owner/repo"


# -----------------------------------------------------------------------------
# OPTIONAL — LangSmith tracing (free tier).
#
# Enables full LangGraph traces in the LangSmith dashboard. Useful for
# debugging the agent loop. Skip if you don't have an account.
# -----------------------------------------------------------------------------

# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=""
# LANGCHAIN_PROJECT="ojas"


# -----------------------------------------------------------------------------
# OPTIONAL — CORS origins (comma-separated). Default: localhost dev origins.
# Set explicitly when you deploy behind a public domain.
# -----------------------------------------------------------------------------

# OJAS_CORS_ORIGINS="https://ojas.yourdomain.com"
